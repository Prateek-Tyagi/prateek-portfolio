# Copy to backend.hcl and fill in, then:
#   terraform init -backend-config=backend.hcl
#
# The bucket must already exist (create it with the bootstrap/ config first).
# No DynamoDB table is needed — locking uses the native S3 lockfile.

bucket = "prateek-portfolio-tfstate-<ACCOUNT_ID>"    # must be globally unique
key    = "prateek-portfolio/terraform.tfstate"
region = "eu-west-2"
