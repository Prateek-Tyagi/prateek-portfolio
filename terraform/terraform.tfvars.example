# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

domain_name     = "prateek.co.uk"       # serves the site over HTTPS
redirect_domain = "prateektyagi.com"    # 301 -> https://<domain_name>
aws_region      = "eu-west-2"           # S3 bucket + account resources (ACM is forced to us-east-1)
github_repo     = "Prateek-Tyagi/prateek-portfolio"
budget_email    = "you@example.com"     # monthly budget alert recipient

# Optional (defaults shown):
# create_oidc_provider = false          # true only if the account has no GitHub OIDC provider
# budget_limit_usd     = 5
# github_branch        = "main"

# If GitHub sends an immutable subject (owner/repo IDs embedded), set the exact
# prefix here so the role trust matches. Find it with:
#   gh api /repos/OWNER/REPO/actions/oidc/customization/sub
# github_sub_claim_prefix = "repo:OWNER@OWNER_ID/REPO@REPO_ID"
